# ============================================
# HarnessEval — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# --- Test repo ---
HARNESS_REPO_URL=https://github.com/SWE-agent/test-repo
HARNESS_ISSUE_URL=https://github.com/SWE-agent/test-repo/issues/1

# --- SWE-Agent path ---
SWEAGENT_DIR=../SWE-agent
SWEAGENT_CONFIG_DIR=config/harness_eval

# --- LLM API Keys (uncomment to use) ---
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-proj-...
# DEEPSEEK_API_KEY=sk-...

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# --- Run settings ---
HARNESS_CALL_LIMIT=30
HARNESS_COST_LIMIT=3.0
HARNESS_TIMEOUT=300
