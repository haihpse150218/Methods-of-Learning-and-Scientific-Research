# HarnessEval API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# At least one key is required for real mode.
# Ollama mode (local) works without any keys.

# DeepSeek (cheapest: $0.15/eval)
DEEPSEEK_API_KEY=

# OpenAI (GPT-4o: $0.30/eval)
OPENAI_API_KEY=

# Anthropic (Claude Sonnet 4: $0.35/eval)
ANTHROPIC_API_KEY=
